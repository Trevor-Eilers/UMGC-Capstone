    <ui:VisualElement name="VisualElement" style="flex-grow: 0; width: auto; flex-direction: row; flex-shrink: 0; background-color: rgb(0, 0, 0); border-top-left-radius: 8px; border-top-right-radius: 8px; border-bottom-right-radius: 8px; border-bottom-left-radius: 8px; padding-left: 4px; align-self: flex-start; align-items: flex-start; padding-right: 4px; align-content: center; height: auto; flex-basis: auto; max-height: 30px; justify-content: flex-start; max-width: 150px;">
        <ui:Label text="Label" name="Label" style="color: rgb(255, 255, 255); background-color: rgba(0, 0, 0, 0); border-top-left-radius: 12px; border-top-right-radius: 12px; border-bottom-right-radius: 12px; border-bottom-left-radius: 12px; font-size: 12px;"/>
        <ui:VisualElement tabindex="1" enabled="true" name="ValueContainer" style="flex-grow: 1; position: relative; left: auto; width: auto; height: auto; top: auto; color: rgb(77, 77, 77); background-color: rgb(65, 65, 65); border-top-left-radius: 8px; border-top-right-radius: 8px; border-bottom-right-radius: 8px; border-bottom-left-radius: 8px; align-self: center; justify-content: center; flex-shrink: 0; flex-direction: row; max-width: 50px; margin-right: 0; padding-right: 4px; padding-left: 4px; margin-top: 2px; margin-bottom: 2px;">
