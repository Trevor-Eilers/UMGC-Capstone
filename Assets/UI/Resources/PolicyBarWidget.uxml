        <ui:Slider label="" value="0" high-value="100" name="CitySlider" page-size="0" show-input-field="false" direction="Horizontal" fill="true" style="align-content: flex-end; width: 100%; flex-direction: row-reverse; margin-left: 0; margin-right: 0; height: 25px; flex-shrink: 0; transform-origin: center; scale: 0.75 0.75; flex-basis: auto; font-size: 10px; min-height: 0; aspect-ratio: auto; align-items: auto; justify-content: flex-start; align-self: auto; flex-wrap: nowrap; color: rgb(255, 255, 255);">
            <ui:Label text="City Contribution" style="font-size: 14px; -unity-text-align: middle-left; justify-content: flex-start; align-content: auto; align-self: auto; align-items: auto; margin-left: 0; margin-right: 12px; -unity-font-style: bold; width: 128px;"/>
